# Scraper backend selection
SCRAPER_PROVIDER=twitter241    # x_official | twitter241

# Official X API v2
X_BEARER_TOKEN=

# RapidAPI — twitter-api45 by alexanderxbx
RAPIDAPI_KEY=
RAPIDAPI_HOST=twitter241.p.rapidapi.com

# RapidAPI — Fresh LinkedIn Scraper API (Apidojo) — KA018 LinkedIn agent
# Free tier = 50 calls/MONTH. Cap conservatively per run.
LINKEDIN_RAPIDAPI_KEY=
LINKEDIN_RAPIDAPI_HOST=fresh-linkedin-scraper-api.p.rapidapi.com
LINKEDIN_MAX_API_CALLS_PER_RUN=5
LINKEDIN_MONTHLY_BUDGET=50
LINKEDIN_SLEEP_PAGINATED=2
LINKEDIN_SLEEP_QUERY=3

# OpenRouter LLM gateway
OPENROUTER_API_KEY=
OPENROUTER_MODEL_CLASSIFIER=google/gemini-2.5-flash
OPENROUTER_MODEL_DRAFTER=anthropic/claude-sonnet-4.5

# Turso (shared DB with dashboard)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=
# KA017-specific cap (X agent only; KA018 uses LINKEDIN_MAX_API_CALLS_PER_RUN)
MAX_API_CALLS_PER_RUN=12

# Runtime
LOG_LEVEL=INFO
SCRAPE_SLEEP_SECONDS=5
ENVIRONMENT=dev
