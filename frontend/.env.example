# Frontend environment variables
# For local dev: copy to .env.local
# For Vercel: set in Vercel dashboard → Settings → Environment Variables

# Node backend URL (auth + X-agent Node dashboard).
# Local dev: http://localhost:3001 · Prod: your Render Node backend URL.
VITE_API_URL=http://localhost:3001

# Python dashboard base URL (Brand Visibility: LinkedIn + X iframes).
# Local dev: http://localhost:8000 (uvicorn).
# If unset, the app falls back to the Render deployment:
#   https://kiteai-brand-visibility-py.onrender.com
VITE_PYTHON_URL=http://localhost:8000
